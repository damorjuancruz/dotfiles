[user]
    name = Juan Cruz D'Amor
    email = damorjuancruz@gmail.com
    signingkey = ~/.ssh/id_ed25519.pub

[alias]
    graph = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'

[push]
    autoSetupRemote = true
    followTags = true

[init]
    defaultBranch = main

[gpg]
    format = ssh

[commit]
    gpgsign = true

[remote "origin"]
    prone = true
